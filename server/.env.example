# Server environment variables
# Copy this file to .env inside the /server directory

# ── Prism v2 (MASA-2) — Phase 0 telemetry (OPTIONAL, default OFF) ──────────────
# When PRISM_V2_TELEMETRY=true AND DATABASE_URL is set, the server records
# per-turn item_responses + an audit_log trail (Part C tables) — pure additive
# logging, zero behavior change. Leave unset to run v1 byte-identical.
#   1. Provision Postgres and set DATABASE_URL.
#   2. cd server && npm run migrate   (creates the Part C tables)
#   3. npm run seed:items             (backfills the item bank; also auto-runs on boot)
# PRISM_V2_TELEMETRY=true
# DATABASE_URL=postgres://user:password@localhost:5432/prism
# PGSSLMODE=require   # set when the provider requires TLS (e.g. Azure Postgres)

# ── v1 storage backend (OPTIONAL, default OFF = JSON files) ────────────────────
# When PRISM_PG_STORE=true AND DATABASE_URL is set, v1 sessions/reports/users/etc
# persist to PostgreSQL (tables v1_*) instead of server/data/*.json — survives
# restarts and scale-out. Run `npm run migrate` first to create the tables.
# Leave unset to keep the JSON-file store (v1 byte-identical).
#
# PRODUCTION ROLLOUT (audit C13 — the JSON store is NOT safe beyond a single
# instance; writes are atomic per-file but read-modify-write still races):
#   1. Staging first: set PRISM_PG_STORE=true + DATABASE_URL, run migrate, then
#      smoke-test signup → payment → assessment → scoring → report → consent →
#      erasure end-to-end (storePg round-trip tests: npm test with DATABASE_URL).
#   2. Flip in production during a low-traffic window.
#   3. Rollback = unset the flag (reverts to JSON files). Any sessions written
#      to Postgres during the window will NOT appear in the JSON store — export
#      them first (v1_* tables) or accept the gap. Never run mixed instances.
# PRISM_PG_STORE=true

# ── Prism v2 Phase 2 — Dual-Channel Scorer (OPTIONAL, default OFF) ─────────────
# When PRISM_V2_DUAL_SCORER=true, scoring uses the turn-level k-vote judge panel
# + conformal CI + reconciliation (v1 panel runs as the shadow reference).
# PRISM_V2_DUAL_SCORER=true
# PRISM_JUDGE_K_A=20          # votes on judge model A per turn
# PRISM_JUDGE_K_B=5           # votes on judge model B (different family) per turn
# PRISM_JUDGE_MODEL_B=        # optional 2nd-family model id (defaults to model A)
# PRISM_CONSISTENCY_SAMPLE=0.2
# ADMIN_TOKEN=                # required header (x-admin-token) for /human-rating

# ── Prism v2 (MASA-2) — Phase 3 calibration & equating (OPTIONAL, default OFF) ─
# Offline calibration jobs live in /calibration (Python). They write
# calibration_runs rows; a reviewer FREEZES a run before it is applied.
#   ADMIN_TOKEN   guards the read-only dashboard GET /api/psychometrics
#                 (header: x-admin-token). Unset → dashboard returns 503.
#   PRISM_V2_EQUATING=true  applies the frozen per-scenario kappa to the overall
#                 (re-clamped 0–100). Off → kappa is 0, v1 reproducible.
# ADMIN_TOKEN=REPLACE_WITH_A_LONG_RANDOM_TOKEN
# PRISM_V2_EQUATING=true

# Razorpay credentials
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY
RAZORPAY_KEY_SECRET=REPLACE_WITH_YOUR_SECRET
# Dummy payments (OPTIONAL, default OFF): bypass Razorpay entirely and mint a
# free session (mode='dummy') from the Pay button — works in production too.
# For pre-launch/testing while the gateway account is not live. The payment
# page shows an explicit "test mode — you will not be charged" notice.
# PRISM_DUMMY_PAYMENTS=true
# Skip verification (OPTIONAL, default OFF): route candidates straight from
# payment to the briefing — no identity documents, no phone/room proctor
# setup. Trial/preview periods only; never for certified assessments.
# PRISM_SKIP_VERIFICATION=true
# Re-assessment spacing (Track 0.3): minimum days between attempts for a
# signed-in candidate (growth measurement needs spaced attempts). Default 90;
# 0 disables. Ignored entirely in trial mode (PRISM_DUMMY_PAYMENTS=true).
# PRISM_REASSESSMENT_GAP_DAYS=90
# Study 1 A/B (Track 6.2, OPTIONAL, default OFF): randomly assigns each new
# session to executive vs lite steering, immutably recorded in study_sessions.
# Requires telemetry + ADMIN_TOKEN for the /api/studies plane.
# PRISM_STUDY_STEERING_AB=true
# Glass-box credentials (Track 2, OPTIONAL, default OFF): sign an evidence
# bundle for every completed assessment (Ed25519). Key is base64 PKCS8 DER —
# generate: node -e "const{generateKeyPairSync}=require('crypto');console.log(generateKeyPairSync('ed25519').privateKey.export({type:'pkcs8',format:'der'}).toString('base64'))"
# There is NO fallback key: unset = issuance disabled.
# PRISM_GLASS_BOX=true
# PRISM_CREDENTIAL_SIGNING_KEY=REPLACE_WITH_BASE64_PKCS8_ED25519

# Azure OpenAI — the conversation avatars, director and judging panel all run
# on this deployment (see createCompletion in server/routes/assessment.js).
AZURE_OPENAI_API_KEY=REPLACE_WITH_KEY_1
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-chat-deployment
# AZURE_OPENAI_API_VERSION=2025-04-01-preview

# OpenAI Whisper — speech-to-text for the voice-only test.
# When unset, the voice answer button falls back to browser dictation/typing.
# Option A: regular OpenAI key (platform.openai.com)
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY
OPENAI_WHISPER_MODEL=whisper-1
# Option B: Azure OpenAI — requires a 'whisper' model deployment on the resource.
# Whisper is only available in some regions (e.g. East US 2, Sweden Central,
# West Europe, North Central US). Get KEY 1 from Keys and Endpoint in the portal.
# AZURE_WHISPER_API_KEY=REPLACE_WITH_KEY_1
# AZURE_WHISPER_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_WHISPER_DEPLOYMENT=whisper
# AZURE_WHISPER_API_VERSION=2024-06-01

# Auth
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

# Server
PORT=3001
NODE_ENV=development

# CORS origin (Vite dev server)
CORS_ORIGIN=http://localhost:5173

# Phone-proctor (Phase 3) — second-camera linking over socket.io.
# Front-end dev port used when building the phone QR URL on the LAN.
FRONTEND_PORT=5173
# Optional: a publicly reachable HTTPS base URL (tunnel/deploy) for the phone
# page. When unset, the laptop's LAN IP is used. Phone camera needs HTTPS or a
# localhost/LAN origin that the browser treats as secure.
# PUBLIC_BASE_URL=https://your-tunnel.example.com
# Optional: restrict the socket.io CORS origin in production. Defaults to
# reflecting the request origin (fine for LAN dev).
# PROCTOR_CORS_ORIGIN=https://your-app.example.com

# Email delivery (Phase 6) — emails the score report PDF via SMTP.
# When unset, the "Email report" button falls back to a direct PDF download.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-address@gmail.com
# SMTP_PASS=your-app-password
# MAIL_FROM=your-address@gmail.com
# MAIL_FROM_NAME=StudAI Prism

# ── Prism v2 — scoring & director (all optional; sensible defaults) ───────────
# PRISM_DIRECTOR_ENABLED: rubric-steered Executive director that adaptively
# steers the conversation toward thinly-evidenced dimensions and deploys the
# challenger only when needed. Set to 'false' to revert to the plain director.
# PRISM_DIRECTOR_ENABLED=true
#
# PRISM_JUDGE_SAMPLES: how many independent scoring samples the panel draws per
# assessment (median-voted, position-swap checked). Higher = more stable + more
# cost/latency. Default 5; capped at 25.
# PRISM_JUDGE_SAMPLES=5
#
# PRISM_JUDGE_MODELS: comma-separated EXTRA Azure deployment names to fold into
# the panel as additional model families (true multi-family PoLL). When unset,
# the panel runs on the primary AZURE_OPENAI_DEPLOYMENT with persona/temperature
# /position-swap variants only.
# PRISM_JUDGE_MODELS=gpt-4o-mini,another-deployment

