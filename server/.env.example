# Server environment variables
# Copy this file to .env inside the /server directory

# ── Prism v2 (MASA-2) — Phase 0 telemetry (OPTIONAL, default OFF) ──────────────
# When PRISM_V2_TELEMETRY=true AND DATABASE_URL is set, the server records
# per-turn item_responses + an audit_log trail (Part C tables) — pure additive
# logging, zero behavior change. Leave unset to run v1 byte-identical.
#   1. Provision Postgres and set DATABASE_URL.
#   2. cd server && npm run migrate   (creates the Part C tables)
#   3. npm run seed:items             (backfills the item bank; also auto-runs on boot)
# PRISM_V2_TELEMETRY=true
# DATABASE_URL=postgres://user:password@localhost:5432/prism
# PGSSLMODE=require   # set when the provider requires TLS (e.g. Azure Postgres)

# ── v1 storage backend (OPTIONAL, default OFF = JSON files) ────────────────────
# When PRISM_PG_STORE=true AND DATABASE_URL is set, v1 sessions/reports/users/etc
# persist to PostgreSQL (tables v1_*) instead of server/data/*.json — survives
# restarts and scale-out. Run `npm run migrate` first to create the tables.
# Leave unset to keep the JSON-file store (v1 byte-identical).
#
# PRODUCTION ROLLOUT (audit C13 — the JSON store is NOT safe beyond a single
# instance; writes are atomic per-file but read-modify-write still races):
#   1. Staging first: set PRISM_PG_STORE=true + DATABASE_URL, run migrate, then
#      smoke-test signup → payment → assessment → scoring → report → consent →
#      erasure end-to-end (storePg round-trip tests: npm test with DATABASE_URL).
#   2. Flip in production during a low-traffic window.
#   3. Rollback = unset the flag (reverts to JSON files). Any sessions written
#      to Postgres during the window will NOT appear in the JSON store — export
#      them first (v1_* tables) or accept the gap. Never run mixed instances.
# PRISM_PG_STORE=true

# ── Prism v2 Phase 2 — Dual-Channel Scorer (OPTIONAL, default OFF) ─────────────
# When PRISM_V2_DUAL_SCORER=true, scoring uses the turn-level k-vote judge panel
# + conformal CI + reconciliation (v1 panel runs as the shadow reference).
# PRISM_V2_DUAL_SCORER=true
# PRISM_JUDGE_K_A=20          # votes on judge model A per turn
# PRISM_JUDGE_K_B=5           # votes on judge model B (different family) per turn
# PRISM_JUDGE_MODEL_B=        # optional 2nd-family model id (defaults to model A)
# PRISM_CONSISTENCY_SAMPLE=0.2
# ADMIN_TOKEN=                # required header (x-admin-token) for /human-rating

# ── Prism v2 (MASA-2) — Phase 3 calibration & equating (OPTIONAL, default OFF) ─
# Offline calibration jobs live in /calibration (Python). They write
# calibration_runs rows; a reviewer FREEZES a run before it is applied.
#   ADMIN_TOKEN   guards the read-only dashboard GET /api/psychometrics
#                 (header: x-admin-token). Unset → dashboard returns 503.
#   PRISM_V2_EQUATING=true  applies the frozen per-scenario kappa to the overall
#                 (re-clamped 0–100). Off → kappa is 0, v1 reproducible.
# ADMIN_TOKEN=REPLACE_WITH_A_LONG_RANDOM_TOKEN
# PRISM_V2_EQUATING=true

# Razorpay credentials
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY
RAZORPAY_KEY_SECRET=REPLACE_WITH_YOUR_SECRET
# Dummy payments (OPTIONAL, default OFF): bypass Razorpay entirely and mint a
# free session (mode='dummy') from the Pay button — works in production too.
# For pre-launch/testing while the gateway account is not live. The payment
# page shows an explicit "test mode — you will not be charged" notice.
# PRISM_DUMMY_PAYMENTS=true
# Skip verification (OPTIONAL, default OFF): route candidates straight from
# payment to the briefing — no identity documents, no phone/room proctor
# setup. Trial/preview periods only; never for certified assessments.
# PRISM_SKIP_VERIFICATION=true
# Re-assessment spacing (Track 0.3): minimum days between attempts for a
# signed-in candidate (growth measurement needs spaced attempts). Default 90;
# 0 disables. Ignored entirely in trial mode (PRISM_DUMMY_PAYMENTS=true).
# PRISM_REASSESSMENT_GAP_DAYS=90
# Study 1 A/B (Track 6.2, OPTIONAL, default OFF): randomly assigns each new
# session to executive vs lite steering, immutably recorded in study_sessions.
# Requires telemetry + ADMIN_TOKEN for the /api/studies plane.
# PRISM_STUDY_STEERING_AB=true
# Glass-box credentials (Track 2, OPTIONAL, default OFF): sign an evidence
# bundle for every completed assessment (Ed25519). Key is base64 PKCS8 DER —
# generate: node -e "const{generateKeyPairSync}=require('crypto');console.log(generateKeyPairSync('ed25519').privateKey.export({type:'pkcs8',format:'der'}).toString('base64'))"
# There is NO fallback key: unset = issuance disabled.
# PRISM_GLASS_BOX=true
# PRISM_CREDENTIAL_SIGNING_KEY=REPLACE_WITH_BASE64_PKCS8_ED25519
# Pressure dynamics (Track 3.2, OPTIONAL, default OFF): lets the Executive
# director deploy fair, skill-mapped pressure moves (contingency shift /
# micro-response / callback — see docs/pressure-probes-v1.md) that also make
# external-LLM relaying detectably laggy. Only active on executive sessions.
# PRISM_PRESSURE=true
# Multilingual assessment path (Track 4.1, OPTIONAL, default OFF): candidates
# can take the assessment in Hinglish, Hindi or Tamil (human decision
# 2026-07-05). ALL non-English scoring is provisional/uncalibrated until the
# multilingual DIF study reports — every artifact carries that marking.
# PRISM_LANG=true
# Counterfactual replay (Track 5.1, OPTIONAL, default OFF): candidates can
# retry their weakest moments after certification. PRACTICE ONLY — replay
# writes a separate practice ledger and can never touch a certified score.
# PRISM_REPLAY=true
# Team-fit simulation (Track 5.2, OPTIONAL, default OFF): avatar twins from
# CONSENTED team profiles (teamfit_profile_use scope, verified per member).
# Output is qualitative observations only — no fit score exists, by design.
# PRISM_TEAMFIT=true
# Skill velocity (Track 1, OPTIONAL, default OFF): growth trajectories from
# the candidate timeline. Growth is stated only from >=3 equated measurement
# points with a slope distinguishable from zero — see server/psychometrics/GROWTH.md.
# Stays dark until the test_retest study has real data.
# PRISM_VELOCITY=true

# ── Admin Control Centre (OPTIONAL, default OFF — ships dark) ──────────────────
# Database-backed administrator identities with mandatory TOTP MFA, RBAC and an
# immutable admin audit trail (docs/admin/ADMIN_CONTROL_CENTRE_PLAN.md).
# Requires DATABASE_URL + `npm run migrate` (0011). Bootstrap the first super
# administrator with:
#   PRISM_ADMIN_BOOTSTRAP_PASSWORD='<temp password, >=12 chars>' \
#     node db/seedAdmin.js --email you@example.com
# Then sign in at /admin/login (change password + enrol authenticator app).
# The legacy ADMIN_TOKEN planes are unaffected until Control Centre Phase 6.
# PRISM_ADMIN_CONSOLE=true
# Optional dedicated key for encrypting TOTP secrets at rest (falls back to a
# key derived from JWT_SECRET when unset):
# PRISM_ADMIN_MFA_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET
# Phase 6 — legacy shared-token retirement: once administrators use the
# console, set this to retire x-admin-token on every legacy plane at once
# (pilot/psychometrics/studies/credentials/teamfit/velocity/human-rating).
# Emergency access then goes through the console's audited break-glass
# account, never an anonymous header. Default off = token still accepted.
# PRISM_ADMIN_TOKEN_DISABLED=true
# LEGAL REVIEW FLAG (Track 4.2): demographic fields beyond language
# (candidate_demographics: gender/language_medium/college_tier) are OPTIONAL
# and DEFAULT-OFF — nothing in the app populates them. Which fields may be
# collected per market (e.g. NYC LL144) is a human/legal decision; do not
# enable collection without documented market-specific approval.

# AWS AI gateway. Authentication uses the AWS SDK default credential provider
# chain. Production should use an IAM role (ECS/App Runner task role, EC2 role,
# or federated web identity) — never put long-lived AWS keys in this file.
AI_PROVIDER=aws-bedrock
AWS_REGION=ap-south-1
# AWS_PROFILE=bedrock  # local development only

# Task-routed Bedrock models. The judge model is the measurement instrument and
# never falls back automatically. Global inference can process data outside
# India; approve that transfer explicitly before using the default primary.
# Availability checked 2026-07-16: Mistral Large 3, Ministral 14B, Voxtral Mini,
# Titan Text Embeddings V2, and Polly neural voices are available in ap-south-1.
# Claude Sonnet 5 and Nova 2 Lite use global inference from the Mumbai endpoint.
BEDROCK_PRIMARY_MODEL=global.anthropic.claude-sonnet-5
# Required in production while any configured model uses global.*. Set only
# after approving cross-border processing and updating candidate disclosures.
# BEDROCK_ALLOW_GLOBAL_INFERENCE=true
BEDROCK_CONVERSATION_MODEL=mistral.mistral-large-3-675b-instruct
BEDROCK_FAST_MODEL=mistral.ministral-3-14b-instruct
BEDROCK_FALLBACK_MODEL=global.amazon.nova-2-lite-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_MULTIMODAL_MODEL=mistral.mistral-large-3-675b-instruct
BEDROCK_TIMEOUT_MS=25000
# Judges receive full transcripts and run as a parallel panel, so their per-call
# timeout is deliberately longer than the interactive conversation timeout.
BEDROCK_JUDGE_TIMEOUT_MS=60000
# BEDROCK_PROMPT_CACHE=true
# BEDROCK_GUARDRAIL_ID=
# BEDROCK_GUARDRAIL_VERSION=
# Optional model-rate overrides for estimated per-call cost logs:
# BEDROCK_COST_RATES_JSON={"model-id":{"inputPerMillion":1,"outputPerMillion":5}}

# In-memory speech-to-text through Bedrock Voxtral. Set both values to enable it.
# Raw audio is sent as an AudioBlock and never written to disk or S3. When
# disabled, the client falls back to browser dictation/typing.
# BEDROCK_STT_ENABLED=true
BEDROCK_STT_MODEL=mistral.voxtral-mini-3b-2507

# Optional output-only persona speech through Amazon Polly. Both this provider
# gate and PRISM_TTS_NEURAL must be true; otherwise browser voices are used.
# POLLY_TTS_ENABLED=true
# POLLY_REGION=ap-south-1
# POLLY_TIMEOUT_MS=15000

# Auth
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

# Server
PORT=3001
NODE_ENV=development

# CORS origin (Vite dev server)
CORS_ORIGIN=http://localhost:5173

# Phone-proctor (Phase 3) — second-camera linking over socket.io.
# Front-end dev port used when building the phone QR URL on the LAN.
FRONTEND_PORT=5173
# Optional: a publicly reachable HTTPS base URL (tunnel/deploy) for the phone
# page. When unset, the laptop's LAN IP is used. Phone camera needs HTTPS or a
# localhost/LAN origin that the browser treats as secure.
# PUBLIC_BASE_URL=https://your-tunnel.example.com
# Optional: restrict the socket.io CORS origin in production. Defaults to
# reflecting the request origin (fine for LAN dev).
# PROCTOR_CORS_ORIGIN=https://your-app.example.com

# Email delivery (Phase 6) — emails the score report PDF via SMTP.
# When unset, the "Email report" button falls back to a direct PDF download.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-address@gmail.com
# SMTP_PASS=your-app-password
# MAIL_FROM=your-address@gmail.com
# MAIL_FROM_NAME=StudAI Prism

# ── Prism v2 — scoring & director (all optional; sensible defaults) ───────────
# PRISM_DIRECTOR_ENABLED: rubric-steered Executive director that adaptively
# steers the conversation toward thinly-evidenced dimensions and deploys the
# challenger only when needed. Set to 'false' to revert to the plain director.
# PRISM_DIRECTOR_ENABLED=true
#
# PRISM_JUDGE_SAMPLES: how many independent scoring samples the panel draws per
# assessment (median-voted, position-swap checked). Higher = more stable + more
# cost/latency. Default 5; capped at 25.
# PRISM_JUDGE_SAMPLES=5
#
# PRISM_JUDGE_MODELS: comma-separated EXTRA configured Bedrock model IDs to
# fold into the panel as additional families (true multi-family PoLL). Every
# score-affecting model remains subject to the fingerprint/re-anchoring law.
# PRISM_JUDGE_MODELS=mistral.mistral-large-3-675b-instruct

