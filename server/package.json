    "@aws-sdk/client-sts": "3.1088.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.13.1",
    "razorpay": "^2.9.4",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.1"
