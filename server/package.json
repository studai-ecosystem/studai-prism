    "seed:items": "node config/runWithRuntimeSecrets.js db/seedItems.js",
    "seed:admin": "node config/runWithRuntimeSecrets.js db/seedAdmin.js",
    "test": "node --test"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "3.1088.0",
    "@aws-sdk/client-polly": "3.1088.0",
