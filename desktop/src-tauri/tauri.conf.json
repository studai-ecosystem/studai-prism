{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prism Assessment",
  "version": "1.0.0",
  "identifier": "one.studai.prism.shell",
  "build": {
    "frontendDist": "../shell-dist"
  },
  "app": {
    "windows": [
      {
        "title": "Prism Assessment",
        "url": "https://prism.studai.one/",
        "userAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) PrismShell/1.0",
        "fullscreen": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "maximized": true,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
