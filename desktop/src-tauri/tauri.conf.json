{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prism Assessment",
  "version": "1.0.0",
  "identifier": "one.studai.prism.shell",
  "build": {
    "frontendDist": "../shell-dist"
  },
  "app": {
    "windows": [
      {
        "title": "Prism Assessment",
        "url": "https://prism.studai.one/app",
        "userAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) PrismShell/1.1",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "fullscreen": false,
        "decorations": true,
        "alwaysOnTop": false,
        "resizable": true,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": false
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["prism"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
